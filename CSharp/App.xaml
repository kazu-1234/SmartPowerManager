<Application
    x:Class="SmartPowerManager.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmartPowerManager">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <x:Double x:Key="UtilityPageMaxWidth">720</x:Double>
            <x:Double x:Key="PageContentMaxWidth">1200</x:Double>
            <x:Double x:Key="PageHostMinWidth">560</x:Double>
            <x:Double x:Key="PageHostNarrowMinWidth">480</x:Double>
            <x:Double x:Key="PageHostMaxWidth">1400</x:Double>
            <x:Double x:Key="PageHostPadding">24</x:Double>
            <Thickness x:Key="PageHostMargin">16,12,16,16</Thickness>
            <x:Double x:Key="SettingsCardSpacing">4</x:Double>
            <x:Double x:Key="CompactNumberBoxWidth">52</x:Double>

            <Style x:Key="PageHostScrollViewerStyle" TargetType="ScrollViewer">
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Top" />
            </Style>

            <Style x:Key="PageBaseStackPanelStyle" TargetType="StackPanel">
                <Setter Property="Width" Value="{StaticResource UtilityPageMaxWidth}" />
                <Setter Property="MaxWidth" Value="{StaticResource UtilityPageMaxWidth}" />
                <Setter Property="Margin" Value="0,8,0,16" />
                <Setter Property="Spacing" Value="{StaticResource SettingsCardSpacing}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SchedulePageStackPanelStyle" TargetType="StackPanel">
                <Setter Property="Margin" Value="0" />
                <Setter Property="Spacing" Value="{StaticResource SettingsCardSpacing}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="CardFormTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CardHeaderTextStyle}">
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleTextBlockStyle}">
                <Setter Property="Margin" Value="0" />
            </Style>

            <Style x:Key="CardHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            </Style>

            <Style x:Key="CardDescriptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="SettingsSectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionHeaderStyle}">
                <Setter Property="Margin" Value="0,20,0,4" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinWidth" Value="44" />
                <Setter Property="Padding" Value="12,8" />
            </Style>

            <Style x:Key="PatternListItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="MinHeight" Value="56" />
                <Setter Property="MinWidth" Value="0" />
            </Style>

            <Style x:Key="DeleteIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ScheduleToggleSwitchStyle" TargetType="ToggleSwitch">
                <!-- レイアウト幅をスイッチ本体分確保し、右端で切れないようにする -->
                <Setter Property="MinWidth" Value="44" />
                <Setter Property="MaxWidth" Value="44" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="4,0,8,0" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="OnContent" Value="{x:Null}" />
                <Setter Property="OffContent" Value="{x:Null}" />
            </Style>

            <Style x:Key="FormRowStackPanelStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal" />
                <Setter Property="Spacing" Value="6" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Padding" Value="0,0,2,0" />
            </Style>

            <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="CompactNumberBoxStyle" TargetType="NumberBox">
                <Setter Property="Width" Value="{StaticResource CompactNumberBoxWidth}" />
                <Setter Property="Padding" Value="4,2" />
                <Setter Property="SpinButtonPlacementMode" Value="Inline" />
                <Setter Property="SmallChange" Value="1" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style x:Key="ScheduleFormRowStyle" TargetType="Grid">
                <Setter Property="Padding" Value="0,4" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ScheduleCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,10,18,10" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ScheduleRowDividerStyle" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <Setter Property="Opacity" Value="0.5" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
