<UserControl
    x:Class="SmartPowerManager.Views.CompactDateTimeInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:SmartPowerManager.Views">
    <StackPanel Orientation="Horizontal" Spacing="4">
        <ComboBox x:Name="YearBox"
                  Style="{StaticResource CompactComboBoxStyle}"
                  SelectionChanged="YearOrMonth_Changed" />
        <ComboBox x:Name="MonthBox"
                  Style="{StaticResource CompactComboBoxStyle}"
                  SelectionChanged="YearOrMonth_Changed" />
        <ComboBox x:Name="DayBox"
                  Style="{StaticResource CompactComboBoxStyle}"
                  SelectionChanged="DayBox_SelectionChanged" />
        <views:CompactTimeInput x:Name="TimeInput" TimeChanged="TimeInput_TimeChanged" />
    </StackPanel>
</UserControl>
