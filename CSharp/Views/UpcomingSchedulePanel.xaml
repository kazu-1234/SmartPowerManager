<UserControl
    x:Class="SmartPowerManager.Views.UpcomingSchedulePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SmartPowerManager.Models"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Center">
    <Border x:Name="RootBorder"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,10,18,10"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ListRow" Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderBlock"
                       Text="実行予定"
                       Style="{StaticResource CardFormTitleStyle}"
                       Height="28"
                       VerticalAlignment="Center" />

            <Grid Grid.Row="1" VerticalAlignment="Stretch">
                <TextBlock x:Name="EmptyStateText"
                           Text="予定はありません"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Visibility="Collapsed" />
                <ScrollViewer x:Name="ScheduleScroll"
                              VerticalAlignment="Stretch"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled">
                    <ItemsControl x:Name="ScheduleList" VerticalAlignment="Top">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:UpcomingScheduleEntry">
                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        Margin="0,0,0,4"
                                        Height="52"
                                        HorizontalAlignment="Stretch">
                                    <!-- 種別バッジ幅を固定し、日時列の縦位置を揃える -->
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" MinWidth="0" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="6,4"
                                                MinWidth="84"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind CategoryLabel}"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="1"
                                                    VerticalAlignment="Center"
                                                    MinWidth="0"
                                                    Margin="4,0,0,0">
                                            <TextBlock Text="{x:Bind Description}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind DateTimeText}"
                                                       Opacity="0.75"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource DeleteIconButtonStyle}"
                                                    Tag="{x:Bind}"
                                                    Visibility="{x:Bind SupportsDeleteAll}"
                                                    Click="RemoveAllButton_Click"
                                                    ToolTipService.ToolTip="このスケジュールをすべて削除">
                                                <FontIcon Glyph="&#xE894;"
                                                          FontSize="14"
                                                          FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </Button>
                                            <Button Style="{StaticResource DeleteIconButtonStyle}"
                                                    Tag="{x:Bind}"
                                                    Click="RemoveEntryButton_Click"
                                                    ToolTipService.ToolTip="この回だけ削除">
                                                <FontIcon Glyph="&#xE74D;"
                                                          FontSize="14"
                                                          FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
